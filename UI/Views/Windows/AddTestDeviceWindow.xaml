<Window x:Class="SANJET.UI.Views.Windows.AddTestDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="添加測試區設備"
        Width="480"
        Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <TextBlock Grid.Row="0" 
                   Text="在測試區新增 ESP32 RS485 設備"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#17313F"
                   Margin="0,0,0,15"/>

        <!-- 說明文字 -->
        <TextBlock Grid.Row="1"
                   Text="使用 RS485 通訊協議配置 Modbus 從站。支持無限制數量（Modbus 最多 247 個從站）。"
                   FontSize="12"
                   Foreground="#666666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15"/>

        <!-- 設備名稱 -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,0,0,12">
            <TextBlock Text="設備名稱" FontSize="14" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                <TextBox Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12"
                         Padding="10"
                         Background="White"
                         Height="35"
                         VerticalContentAlignment="Center"/>
            </Border>
            <TextBlock Text="例如：實驗裝置1、測試馬達、新型傳感器等"
                       FontSize="11"
                       Foreground="#999999"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- ESP32 MQTT ID -->
        <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,0,0,12">
            <TextBlock Text="ESP32 MQTT ID" FontSize="14" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                <TextBox Text="{Binding Esp32MqttId, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12"
                         Padding="10"
                         Background="White"
                         Height="35"
                         VerticalContentAlignment="Center"/>
            </Border>
            <TextBlock Text="不同的 ESP32 設備應使用不同的 ID (建議測試用：ESP32_TEST_RS485)"
                       FontSize="11"
                       Foreground="#999999"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Modbus Slave ID -->
        <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,0,0,12">
            <TextBlock Text="Modbus Slave ID (1-247)" FontSize="14" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                <TextBox Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12"
                         Padding="10"
                         Background="White"
                         Height="35"
                         VerticalContentAlignment="Center"/>
            </Border>
            <TextBlock Text="Modbus 標準支援 1-247 任意 Slave ID。若第一站有 4 台邏輯設備，可使用相同 Slave ID 搭配下方設備編號。"
                       FontSize="11"
                       Foreground="#999999"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- 測試區邏輯設備編號 -->
        <StackPanel Grid.Row="5" Orientation="Vertical" Margin="0,0,0,12">
            <TextBlock Text="測試區設備編號 (1-4)" FontSize="14" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                <TextBox Text="{Binding ModbusDeviceIndex, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12"
                         Padding="10"
                         Background="White"
                         Height="35"
                         VerticalContentAlignment="Center"/>
            </Border>
            <TextBlock Text="同一個 Slave ID 內：設備1~4 控制=0~3、狀態=10~13、次數從20開始。"
                       FontSize="11"
                       Foreground="#999999"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Modbus RS485 配置提示 -->
        <Border Grid.Row="6"
                Background="#E8F4F8"
                BorderBrush="#0099CC"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="RS485 配置信息" FontSize="12" FontWeight="Bold" Foreground="#0066AA" Margin="0,0,0,8"/>
                <TextBlock Text="• 通訊方式：Modbus RTU 或 TCP" FontSize="11" Foreground="#333333" TextWrapping="Wrap" Margin="0,0,0,4"/>
                <TextBlock Text="• 每個 ESP32 支持最多 247 個 Modbus 從站（無數量限制）" FontSize="11" Foreground="#333333" TextWrapping="Wrap" Margin="0,0,0,4"/>
                <TextBlock Text="• 測試區第一站範例：設備1~4 的控制 0~3、狀態 10~13、次數 20 起算" FontSize="11" Foreground="#333333" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 狀態信息 -->
        <TextBlock Grid.Row="7"
                   Text="{Binding StatusMessage}"
                   FontSize="12"
                   Foreground="#E74C3C"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"
                   MinHeight="20"/>

        <!-- 按鈕 -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="添加"
                    Command="{Binding AddDeviceCommand}"
                    Width="100"
                    Height="40"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="14"
                    Margin="0,0,10,0"
                    Cursor="Hand"/>
            <Button Content="取消"
                    Command="{Binding CancelCommand}"
                    Width="100"
                    Height="40"
                    Background="#757575"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="14"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
