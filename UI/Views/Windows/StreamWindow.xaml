<Window x:Class="SANJET.UI.Views.Windows.StreamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="RTSP 串流"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#FF2D2D30"
        Foreground="White"
        WindowStyle="SingleBorderWindow">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 標題欄 -->
        <Border Grid.Row="0"
                Background="#FF3E3E42"
                Padding="15,10"
                BorderBrush="#FF555555"
                BorderThickness="0,0,0,1">
            <TextBlock Text="RTSP 串流預覽"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"/>
        </Border>

        <!-- 視頻顯示區域 -->
        <Border Grid.Row="1"
                Background="Black"
                Padding="10"
                Margin="10">
            <Grid>
                <vlc:VideoView x:Name="RtspVideoView"/>

                <TextBlock x:Name="StreamStatusText"
                           Text="未連接"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Panel.ZIndex="10"/>
            </Grid>
        </Border>

        <!-- 控制按鈕 -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="15"
                    VerticalAlignment="Center">
            <Button Content="斷開連接"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Click="DisconnectStream_Click"
                    Background="#FFE74C3C"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    FontWeight="Bold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="關閉"
                    Width="100"
                    Height="40"
                    Margin="5"
                    Click="Close_Click"
                    Background="#FF555555"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    FontWeight="Bold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
