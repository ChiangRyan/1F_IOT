<Page x:Class="SANJET.UI.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SANJET.UI.Views.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="SettingsPage">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock Text="{Binding PageTitle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" />

            <GroupBox Header="資料庫管理" Padding="10" MinWidth="300">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                        您可以在此處備份應用程式的本地資料庫，或從先前的備份檔案還原。
                        <LineBreak/>
                        <Run FontWeight="Bold">注意：</Run>還原操作會覆蓋現有資料並重啟應用程式。
                    </TextBlock>

                    <Button Content="備份資料庫..."
                            Command="{Binding BackupDatabaseCommand}"
                            Margin="0,5"
                            Padding="10,5"/>

                    <Button Content="從備份還原..."
                            Command="{Binding RestoreDatabaseCommand}"
                            Margin="0,5"
                            Padding="10,5"
                            Background="OrangeRed"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="RTSP 串流設定" Padding="10" MinWidth="700" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                        請在此設定攝影機帳號、密碼與 IP。
                        <LineBreak/>
                        首頁按下「RTSP 串流」按鈕後，會以此設定開啟影像視窗。
                    </TextBlock>

                    <UniformGrid Columns="2" Rows="5" Margin="0,0,0,10">
                        <TextBlock Text="IP 位址：" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox x:Name="IpAddressTextBox" Margin="0,0,0,8" Padding="6"/>

                        <TextBlock Text="連接埠：" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox x:Name="PortTextBox" Margin="0,0,0,8" Padding="6"/>

                        <TextBlock Text="帳號：" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox x:Name="UsernameTextBox" Margin="0,0,0,8" Padding="6"/>

                        <TextBlock Text="密碼：" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8" Padding="6"/>

                        <TextBlock Text="串流路徑(選填)：" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox x:Name="PathTextBox" Margin="0,0,0,8" Padding="6"/>
                    </UniformGrid>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="儲存 RTSP 設定"
                                Width="140"
                                Padding="10,5"
                                Click="SaveRtspSettingsButton_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="RtspStatusTextBlock"
                               Text="狀態：尚未儲存"
                               Margin="0,10,0,0"
                               Foreground="Gray"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Page>
