<Page x:Class="SANJET.UI.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SANJET.UI.Views.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="SettingsPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 標題 -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="應用程式設定"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#222"/>

                    <TextBlock Text="管理資料庫備份、RTSP 攝影機連線參數與串流畫質。"
                       FontSize="14"
                       Foreground="#666"
                       Margin="0,6,0,0"/>
                </StackPanel>

                <!-- 資料庫管理 -->
                <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,18"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Opacity="0.8">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="資料庫管理"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>

                            <TextBlock Text="備份本地資料庫，或從備份檔案還原。還原會覆蓋現有資料並重啟應用程式。"
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#6B7280"
                               Margin="0,6,20,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                            <Button Content="備份"
                            Width="82"
                            Height="32"
                            Margin="0,0,8,0"
                            Command="{Binding BackupDatabaseCommand}"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"/>

                            <Button Content="還原"
                            Width="82"
                            Height="32"
                            Command="{Binding RestoreDatabaseCommand}"
                            Background="#EF4444"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RTSP 設定 -->
                <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="18"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Opacity="0.8">

                    <StackPanel>
                        <DockPanel Margin="0,0,0,18">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="RTSP 參數設定"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"/>

                                <TextBlock Text="設定兩組攝影機的 IP、帳號、密碼與串流畫質。"
                                   FontSize="13"
                                   Foreground="#6B7280"
                                   Margin="0,6,0,0"/>
                            </StackPanel>

                            <Button Content="儲存設定"
                            DockPanel.Dock="Right"
                            Width="110"
                            Height="34"
                            HorizontalAlignment="Right"
                            Command="{Binding SaveRtspSettingsCommand}"
                            Background="#10B981"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"/>
                        </DockPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 攝像頭 1 -->
                            <Border Grid.Column="0"
                            Background="#F8FAFC"
                            CornerRadius="10"
                            Padding="16"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1">

                                <StackPanel>
                                    <TextBlock Text="攝像頭 1"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#2563EB"
                                       Margin="0,0,0,14"/>

                                    <TextBlock Text="IP 位址" Foreground="#374151" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding RtspIpAddress, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     Height="30"
                                     Margin="0,4,0,10"/>

                                    <TextBlock Text="連接埠" Foreground="#374151" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding RtspPort, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     Height="30"
                                     Margin="0,4,0,10"/>

                                    <TextBlock Text="帳號" Foreground="#374151" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding RtspUsername, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     Height="30"
                                     Margin="0,4,0,10"/>

                                    <TextBlock Text="密碼" Foreground="#374151" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding RtspPassword, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     Height="30"
                                     Margin="0,4,0,10"/>

                                    <TextBlock Text="串流畫質" Foreground="#374151" FontWeight="SemiBold"/>
                                    <ComboBox SelectedValue="{Binding RtspStreamPath, Mode=TwoWay}"
                                      VerticalContentAlignment="Center"
                                      SelectedValuePath="Tag"
                                      Height="32"
                                      Margin="0,4,0,0">
                                        <ComboBoxItem Content="高畫質" Tag="stream1"/>
                                        <ComboBoxItem Content="低畫質" Tag="stream2"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <!-- 攝像頭 2 -->
                            <Border Grid.Column="2"
                            Background="#F8FAFC"
                            CornerRadius="10"
                            Padding="16"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1">

                                <StackPanel>
                                    <TextBlock Text="攝像頭 2"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#2563EB"
                                       Margin="0,0,0,14"/>

                                    <TextBlock Text="IP 位址" Foreground="#374151" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding RtspIpAddress2, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     Height="30"
                                     Margin="0,4,0,10"/>

                                    <TextBlock Text="連接埠" Foreground="#374151" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding RtspPort2, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     Height="30"
                                     Margin="0,4,0,10"/>

                                    <TextBlock Text="帳號" Foreground="#374151" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding RtspUsername2, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     Height="30"
                                     Margin="0,4,0,10"/>

                                    <TextBlock Text="密碼" Foreground="#374151" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding RtspPassword2, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"
                                     Height="30"
                                     Margin="0,4,0,10"/>

                                    <TextBlock Text="串流畫質" Foreground="#374151" FontWeight="SemiBold"/>
                                    <ComboBox SelectedValue="{Binding RtspStreamPath2, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Height="32"
                                      Margin="0,4,0,0"
                                      VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="高畫質" Tag="stream1"/>
                                        <ComboBoxItem Content="低畫質" Tag="stream2"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
