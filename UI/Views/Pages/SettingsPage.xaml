<Page x:Class="SANJET.UI.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SANJET.UI.Views.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="SettingsPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" HorizontalAlignment="Left" VerticalAlignment="Top">
                <TextBlock Text="應用程式設定"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20" />

                <GroupBox Header="資料庫管理" Padding="10" MinWidth="300">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                            您可以在此處備份應用程式的本地資料庫，或從先前的備份檔案還原。
                            <LineBreak/>
                            <Run FontWeight="Bold">注意：</Run>還原操作會覆蓋現有資料並重啟應用程式。
                        </TextBlock>

                        <Button Content="備份資料庫..."
                                Command="{Binding BackupDatabaseCommand}"
                                Margin="0,5"
                                Padding="10,5"/>

                        <Button Content="從備份還原..."
                                Command="{Binding RestoreDatabaseCommand}"
                                Margin="0,5"
                                Padding="10,5"
                                Background="OrangeRed"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="RTSP 參數設定" Padding="10" MinWidth="500" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                            可在此設定 RTSP 帳號、密碼與 IP。
                        </TextBlock>

                        <!-- 攝像頭 1 -->
                        <TextBlock Text="攝像頭 1" FontWeight="Bold" Margin="0,0,0,10" Foreground="#FF2196F3"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP 位址" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RtspIpAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,8"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="連接埠" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding RtspPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="帳號" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RtspUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="密碼" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding RtspPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="串流路徑" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RtspStreamPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                        </Grid>

                        <!-- 攝像頭 2 -->
                        <TextBlock Text="攝像頭 2" FontWeight="Bold" Margin="0,0,0,10" Foreground="#FF2196F3"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP 位址" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RtspIpAddress2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,8"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="連接埠" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding RtspPort2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="帳號" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RtspUsername2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="密碼" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding RtspPassword2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="串流路徑" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RtspStreamPath2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="儲存 RTSP 設定"
                                    Width="140"
                                    Padding="10,5"
                                    Margin="0,0,10,0"
                                    Command="{Binding SaveRtspSettingsCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
