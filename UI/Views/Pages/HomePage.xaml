<Page x:Class="SANJET.UI.Views.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:SANJET.Core.ViewModels"
      mc:Ignorable="d"
      Title="Home" d:DesignHeight="450" d:DesignWidth="800"
      KeepAlive="True">

    <!-- 定義全局樣式 -->
    <Page.Resources>
        <!-- 統一 TextBlock 樣式 -->
        <Style x:Key="MyTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <!-- 統一 Button 樣式 -->
        <Style x:Key="MyButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="DarkSlateGray"/>
        </Style>
        
        <!-- 統一名稱修改Button 樣式 -->
        <Style x:Key="EditNameBTStyle" TargetType="Button">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="DarkSlateGray"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>

        <Style x:Key="EditButtonStyle" TargetType="Button" BasedOn="{StaticResource EditNameBTStyle}">
            <Setter Property="Background" Value="DodgerBlue"/>
        </Style>

        <Style x:Key="SaveButtonStyle" TargetType="Button" BasedOn="{StaticResource EditNameBTStyle}">
            <Setter Property="Background" Value="MediumSeaGreen"/>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource EditNameBTStyle}">
            <Setter Property="Background" Value="Tomato"/>
        </Style>

        <!-- 紀錄按鈕樣式 -->
        <Style x:Key="RecordButtonStyle" TargetType="Button" BasedOn="{StaticResource EditNameBTStyle}">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="50"/>
        </Style>

        <!-- 啟動按鈕樣式 -->
        <Style x:Key="StartButtonStyle" TargetType="Button" BasedOn="{StaticResource MyButtonStyle}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="IsEnabled" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="運行中">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="通訊失敗">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOperational}" Value="False">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 停止按鈕樣式 -->
        <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource MyButtonStyle}">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="IsEnabled" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="閒置">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="通訊失敗">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOperational}" Value="False">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 統一 CheckBox 樣式 -->
        <Style x:Key="MyCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <!-- 使用 LayoutTransform 整體縮放 -->
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.7" ScaleY="1.7"/>
                    <!-- 調整縮放比例 -->
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 廠區平面圖：點選區域後進入該區設備列表 -->
        <Border Grid.Row="0" Margin="0,0,0,16" Padding="18" CornerRadius="12" BorderBrush="#4F6472" BorderThickness="1" Background="Transparent"
                Visibility="{Binding IsAreaSelected, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="廠區平面圖" FontSize="32" FontWeight="Bold" Foreground="#17313F"/>
                </StackPanel>

                <Grid Grid.Row="1" MinHeight="360">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                            Margin="0,0,12,0"
                            Padding="16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="#DDEFE6"
                            BorderBrush="#2E7D59"
                            Opacity="0.67"
                            BorderThickness="3"
                            Command="{Binding SelectAreaCommand}"
                            CommandParameter="Display" >
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="展機區" FontSize="36" FontWeight="Bold" Foreground="#1F5F43" HorizontalAlignment="Center"/>
                                <TextBlock Text="點選進入" FontSize="18" Foreground="#4D7F65" HorizontalAlignment="Center" Margin="0,18,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button Grid.Row="0" Grid.Column="2"
                            Margin="100,0,0,250"
                            Padding="16"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="#E7ECFA"
                            BorderBrush="#3F5DA8"
                            Opacity="0.7"
                            BorderThickness="3"
                            Command="{Binding SelectAreaCommand}"
                            CommandParameter="Test">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="測試區" FontSize="36" FontWeight="Bold" Foreground="#253E88" HorizontalAlignment="Center"/>
                                <TextBlock Text="新增區域" FontSize="20" Foreground="#5167A6" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                <TextBlock Text="點選進入" FontSize="18" Foreground="#6174AF" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Border Grid.Row="1" Grid.Column="1" Margin="70,0,0,0" CornerRadius="8" Background="#FFF7E7" BorderBrush="#D6A64D" BorderThickness="2" Opacity="0.7">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" >
                            <TextBlock Text="DVC工作區" FontSize="24" FontWeight="SemiBold" Foreground="#7A5A16" HorizontalAlignment="Center"/>
                            <TextBlock Text="保留廠區動線標示" FontSize="16" Foreground="#8C6E2E" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="2" Margin="0,14,0,0" Text="提示：點選展示區或測試區即可查看該區設備。" FontSize="16" Foreground="#657782"/>
            </Grid>
        </Border>

        <!-- 區域設備列表 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12"
                   Visibility="{Binding IsAreaSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Button Content="返回平面圖"
                    DockPanel.Dock="Left"
                    Width="130"
                    Height="38"
                    Margin="0,0,14,0"
                    Command="{Binding BackToFactoryMapCommand}"
                    Background="#4F6472"
                    Foreground="White"
                    FontWeight="Bold"/>
            <!-- 添加設備按鈕（測試區） -->
            <Button Content="添加設備"
                    DockPanel.Dock="Right"
                    Width="100"
                    Height="38"
                    Margin="0,0,0,0"
                    Command="{Binding OpenAddTestDeviceDialogCommand}"
                    Background="#2196F3"
                    Foreground="White"
                    FontWeight="Bold"
                    Visibility="{Binding SelectedAreaName, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=測試區}"/>
            <!-- 添加設備按鈕（展機區） -->
            <Button Content="添加設備"
                    DockPanel.Dock="Right"
                    Width="100"
                    Height="38"
                    Margin="0,0,0,0"
                    Command="{Binding OpenAddDisplayAreaDeviceDialogCommand}"
                    Background="#2196F3"
                    Foreground="White"
                    FontWeight="Bold"
                    Visibility="{Binding SelectedAreaName, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=展機區}"/>
            <StackPanel>
                <TextBlock Text="{Binding SelectedAreaName}" FontSize="24" FontWeight="Bold" Foreground="#17313F"/>
                <TextBlock Text="{Binding SelectedAreaDescription}" FontSize="17" Foreground="#50636F" TextWrapping="Wrap"/>
            </StackPanel>
        </DockPanel>

        <TextBlock Grid.Row="1"
                   Text="此區域尚未配置設備。"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#687985"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding ShowSelectedAreaEmptyMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>

    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                  Visibility="{Binding IsAreaSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
        <ItemsControl ItemsSource="{Binding SelectedAreaDevices}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="6"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5" Padding="10" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#80808080"/>
                                <!-- Gray with 50% opacity -->
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="閒置">
                                        <Setter Property="Background" Value="#80D3D3D3"/>
                                        <!-- LightGray with 50% opacity -->
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="運行中">
                                        <Setter Property="Background" Value="#8090EE90"/>
                                        <!-- LightGreen with 50% opacity -->
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="故障">
                                        <Setter Property="Background" Value="#80F08080"/>
                                        <!-- LightCoral with 50% opacity -->
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="通訊失敗">
                                        <Setter Property="Background" Value="#80800080"/>
                                        <!-- Purple with 50% opacity -->
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <!-- 設備是否正常運作的選擇控件 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5" 
                                Visibility="{
                                    Binding DataContext.CanControlDevice, 
                                    RelativeSource={RelativeSource AncestorType=Page}, 
                                    Converter={StaticResource BooleanToVisibilityConverter}}">

                                <TextBlock Text="是否啟用:" Style="{StaticResource MyTextBlockStyle}"/>
                                <CheckBox IsChecked="{Binding IsOperational, UpdateSourceTrigger=PropertyChanged}" 
                                          Style="{StaticResource MyCheckBoxStyle}"/>
                            </StackPanel>

                            <!-- 名稱輸入 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="名稱：" Style="{StaticResource MyTextBlockStyle}" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="18" 
                                     Width="100" 
                                     VerticalAlignment="Center"
                                     IsReadOnly="{Binding IsEditingName, Converter={StaticResource BooleanInverterConverter}}"/>            

                                <Button Content="修改" 
                                    Command="{Binding EditNameCommand}" 
                                    CommandParameter="{Binding SlaveId}"
                                    Style="{StaticResource EditButtonStyle}" 
                                    Visibility="{Binding IsEditingName, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                    IsEnabled="{Binding DataContext.CanControlDevice, RelativeSource={RelativeSource AncestorType=Page}}"/>
                                <Button Content="保存" 
                                    Command="{Binding SaveNameCommand}" 
                                    CommandParameter="{Binding SlaveId}"
                                    Style="{StaticResource SaveButtonStyle}" 
                                    Visibility="{Binding IsEditingName, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <Button Content="取消" 
                                    Command="{Binding CancelEditNameCommand}" 
                                    CommandParameter="{Binding SlaveId}"
                                    Style="{StaticResource CancelButtonStyle}" 
                                    Visibility="{Binding IsEditingName, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>

                            <TextBlock Style="{StaticResource MyTextBlockStyle}" Text="{Binding ControllingEsp32MqttId, StringFormat=ESP32 ID：{0}}"/>
                            <TextBlock Style="{StaticResource MyTextBlockStyle}" Text="{Binding SlaveId, StringFormat=從站 ID：{0}}"/>
                            <TextBlock Style="{StaticResource MyTextBlockStyle}" Text="{Binding RunCount, StringFormat=跑合：{0}}"/>
                            <TextBlock Style="{StaticResource MyTextBlockStyle}" Text="{Binding Status, StringFormat=狀態：{0}}" FontWeight="Bold" Foreground="DarkSlateBlue"/>
                            <StackPanel Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Center"
                                Visibility="{
                                    Binding DataContext.CanControlDevice, 
                                    RelativeSource={RelativeSource AncestorType=Page}, 
                                    Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Content="啟動" 
                                        x:Name="Start"
                                        Command="{Binding StartCommand}" 
                                        CommandParameter="{Binding SlaveId}"
                                        Style="{StaticResource StartButtonStyle}"
                                        />
                                <Button Content="停止" 
                                        Command="{Binding StopCommand}" 
                                        CommandParameter="{Binding SlaveId}"
                                        Style="{StaticResource StopButtonStyle}"
                                        />
                                
                            </StackPanel>

                            <!-- 新增紀錄按鈕 -->
                            <Button Content="紀錄" Command="{Binding RecordCommand}" CommandParameter="{Binding SlaveId}" Style="{StaticResource RecordButtonStyle}" 
                                    Margin="0,10,0,0" HorizontalAlignment="Center"/>

                            <!-- 編輯模式：輸入新的運轉次數 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,5"
                                Visibility="{Binding IsEditingRunCount, Converter={StaticResource BooleanToVisibilityConverter}}"
                                HorizontalAlignment="Center">
                                <TextBlock Text="設置運轉次數: " Style="{StaticResource MyTextBlockStyle}"/>
                                <TextBox Text="{Binding EditingRunCountText, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="16" 
                                         Width="60" 
                                         VerticalAlignment="Center"/>
                                <Button Content="確認" 
                                        Command="{Binding SaveRunCountCommand}" 
                                        CommandParameter="{Binding SlaveId}"
                                        Style="{StaticResource SaveButtonStyle}"/>
                                <Button Content="取消" 
                                        Command="{Binding CancelEditRunCountCommand}" 
                                        CommandParameter="{Binding SlaveId}"
                                        Style="{StaticResource CancelButtonStyle}"/>
                            </StackPanel>

                            <!-- 編輯按鈕 -->
                            <Button Content="修改運轉次數" 
                                    Command="{Binding EditRunCountCommand}" 
                                    CommandParameter="{Binding SlaveId}"
                                    Style="{StaticResource EditButtonStyle}"
                                    Width="120"
                                    Margin="0,5,0,0"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding IsEditingRunCount, Converter={StaticResource BooleanInverterConverter}}"
                                    IsEnabled="{Binding DataContext.CanControlDevice, RelativeSource={RelativeSource AncestorType=Page}}"/>
                        </StackPanel>

                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>

    </Grid>
</Page>
